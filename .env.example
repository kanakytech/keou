# Keou open-source edition — environment
# Copy to .env and fill in.

# ─── Required ───

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/keou

# Session signing secret (min 16 chars — generate with: openssl rand -hex 32)
JWT_SECRET=

# ─── Storage (recommended) ───
# Cloudflare R2 (free tier works) — stores uploads + results durably.
# Without it, uploads fail and results rely on provider URLs that expire in ~14 days.
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=keou
R2_PUBLIC_URL=

# ─── Optional ───

# Server port (default 3401)
PORT=3401

# Internal generation counters (this edition has no billing — leave unlimited)
AGENCY_IMAGE_QUOTA=999999
AGENCY_VIDEO_QUOTA=999999

# Note: there is no KIE_API_KEY here on purpose. Each user pastes their own
# key in the studio; it is never stored server-side.
